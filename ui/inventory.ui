<?xml version="1.0" encoding="UTF-8"?>
<!-- Generated for Inventory Management System — GTK3 -->
<interface>
  <requires lib="gtk+" version="3.22"/>

  <!-- ══════════════════════════════════════════════════════════════════
       Standalone (non-visual) objects
  ══════════════════════════════════════════════════════════════════ -->

  <!-- Data model for stock treeview
       Column types must match gtk_list_store_set() calls in gui_handlers.c:
         0-1: gchararray  (bar, name)
         2:   gchararray  (price_str — pre-formatted float)
         3-5: gint        (stock, trans, cap — passed as ints)
         6:   gchararray  (per_str — pre-formatted "x.x%")
         7:   gchararray  (status string "Active" / "Discontinued")
  -->
  <object class="GtkListStore" id="stock_liststore">
    <columns>
      <column type="gchararray"/>
      <column type="gchararray"/>
      <column type="gchararray"/>
      <column type="gint"/>
      <column type="gint"/>
      <column type="gint"/>
      <column type="gchararray"/>
      <column type="gchararray"/>
    </columns>
  </object>

  <!-- Adjustments for GtkSpinButtons (min=0, max=999999, step=1) -->
  <object class="GtkAdjustment" id="adj_stock">
    <property name="lower">0</property>
    <property name="upper">999999</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
  </object>

  <object class="GtkAdjustment" id="adj_cap">
    <property name="lower">0</property>
    <property name="upper">999999</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
  </object>

  <object class="GtkAdjustment" id="adj_trans">
    <property name="lower">0</property>
    <property name="upper">999999</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
  </object>

  <!-- ══════════════════════════════════════════════════════════════════
       Main Window
  ══════════════════════════════════════════════════════════════════ -->
  <object class="GtkWindow" id="main_window">
    <property name="title">Inventory Management System</property>
    <property name="default-width">1100</property>
    <property name="default-height">700</property>
    <property name="window-position">center</property>
    <property name="resizable">True</property>
    <signal name="destroy" handler="on_main_window_destroy"/>

    <child>
      <!-- Root vertical box: MenuBar / Toolbar / Notebook / Statusbar -->
      <object class="GtkBox" id="root_box">
        <property name="orientation">vertical</property>
        <property name="spacing">0</property>

        <!-- ── Slot 0: MenuBar ──────────────────────────────────────── -->
        <child>
          <object class="GtkMenuBar" id="menubar">

            <!-- ▸ Inventory -->
            <child>
              <object class="GtkMenuItem" id="menu_inventory">
                <property name="label">Inventory</property>
                <child type="submenu">
                  <object class="GtkMenu">
                    <child>
                      <object class="GtkMenuItem" id="menu_item_add">
                        <property name="label">Add Item</property>
                        <signal name="activate" handler="on_menu_item_add_activate"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkMenuItem" id="menu_item_view">
                        <property name="label">View All Stock</property>
                        <signal name="activate" handler="on_menu_item_view_activate"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkMenuItem" id="menu_item_search">
                        <property name="label">Search by Barcode</property>
                        <signal name="activate" handler="on_menu_item_search_activate"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSeparatorMenuItem"/>
                    </child>
                    <child>
                      <object class="GtkMenuItem" id="menu_item_delete">
                        <property name="label">Delete / Discontinue Item</property>
                        <signal name="activate" handler="on_menu_item_delete_activate"/>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <!-- ▸ File -->
            <child>
              <object class="GtkMenuItem" id="menu_file">
                <property name="label">File</property>
                <child type="submenu">
                  <object class="GtkMenu">
                    <child>
                      <object class="GtkMenuItem" id="menu_item_load">
                        <property name="label">Load CSV</property>
                        <signal name="activate" handler="on_menu_item_load_activate"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkMenuItem" id="menu_item_save">
                        <property name="label">Save CSV</property>
                        <signal name="activate" handler="on_menu_item_save_activate"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSeparatorMenuItem"/>
                    </child>
                    <child>
                      <object class="GtkMenuItem" id="menu_item_quit">
                        <property name="label">Quit</property>
                        <signal name="activate" handler="on_menu_item_quit_activate"/>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <!-- ▸ Help -->
            <child>
              <object class="GtkMenuItem" id="menu_help">
                <property name="label">Help</property>
                <child type="submenu">
                  <object class="GtkMenu">
                    <child>
                      <object class="GtkMenuItem" id="menu_item_about">
                        <property name="label">About</property>
                        <signal name="activate" handler="on_menu_item_about_activate"/>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
          </packing>
        </child>

        <!-- ── Slot 1: Toolbar ─────────────────────────────────────── -->
        <child>
          <object class="GtkToolbar" id="toolbar">
            <child>
              <object class="GtkToolButton" id="tb_add">
                <property name="label">Add</property>
                <property name="icon-name">list-add</property>
                <signal name="clicked" handler="on_tb_add_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkToolButton" id="tb_search">
                <property name="label">Search</property>
                <property name="icon-name">system-search</property>
                <signal name="clicked" handler="on_tb_search_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkToolButton" id="tb_save">
                <property name="label">Save</property>
                <property name="icon-name">document-save</property>
                <signal name="clicked" handler="on_tb_save_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkToolButton" id="tb_refresh">
                <property name="label">Refresh</property>
                <property name="icon-name">view-refresh</property>
                <signal name="clicked" handler="on_tb_refresh_clicked"/>
              </object>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
          </packing>
        </child>

        <!-- ── Slot 2: Notebook (tabs hidden — menu drives navigation) ── -->
        <child>
          <object class="GtkNotebook" id="main_notebook">
            <property name="show-tabs">False</property>

            <!-- ════════════════════════════════════════════════════
                 PAGE 0 — Stock View
            ════════════════════════════════════════════════════ -->
            <child>
              <object class="GtkBox" id="stock_page_box">
                <property name="orientation">vertical</property>
                <property name="spacing">4</property>

                <!-- Scrolled tree view fills the available space -->
                <child>
                  <object class="GtkScrolledWindow" id="stock_scroll">
                    <property name="hscrollbar-policy">automatic</property>
                    <property name="vscrollbar-policy">automatic</property>
                    <child>
                      <object class="GtkTreeView" id="stock_treeview">
                        <property name="model">stock_liststore</property>
                        <property name="headers-visible">True</property>
                        <property name="enable-grid-lines">horizontal</property>
                        <property name="rubber-banding">True</property>

                        <!-- Column 0 — Barcode -->
                        <child>
                          <object class="GtkTreeViewColumn" id="col_barcode">
                            <property name="title">Barcode</property>
                            <property name="resizable">True</property>
                            <property name="min-width">130</property>
                            <child>
                              <object class="GtkCellRendererText"/>
                              <attributes>
                                <attribute name="text">0</attribute>
                              </attributes>
                            </child>
                          </object>
                        </child>

                        <!-- Column 1 — Name -->
                        <child>
                          <object class="GtkTreeViewColumn" id="col_name">
                            <property name="title">Name</property>
                            <property name="resizable">True</property>
                            <property name="expand">True</property>
                            <child>
                              <object class="GtkCellRendererText"/>
                              <attributes>
                                <attribute name="text">1</attribute>
                              </attributes>
                            </child>
                          </object>
                        </child>

                        <!-- Column 2 — Price -->
                        <child>
                          <object class="GtkTreeViewColumn" id="col_price">
                            <property name="title">Price (&#8377;)</property>
                            <property name="resizable">True</property>
                            <child>
                              <object class="GtkCellRendererText"/>
                              <attributes>
                                <attribute name="text">2</attribute>
                              </attributes>
                            </child>
                          </object>
                        </child>

                        <!-- Column 3 — Stock (gint) -->
                        <child>
                          <object class="GtkTreeViewColumn" id="col_stock">
                            <property name="title">Stock</property>
                            <property name="resizable">True</property>
                            <child>
                              <object class="GtkCellRendererText"/>
                              <attributes>
                                <attribute name="text">3</attribute>
                              </attributes>
                            </child>
                          </object>
                        </child>

                        <!-- Column 4 — Transactions (gint) -->
                        <child>
                          <object class="GtkTreeViewColumn" id="col_trans">
                            <property name="title">Transactions</property>
                            <property name="resizable">True</property>
                            <child>
                              <object class="GtkCellRendererText"/>
                              <attributes>
                                <attribute name="text">4</attribute>
                              </attributes>
                            </child>
                          </object>
                        </child>

                        <!-- Column 5 — Capacity (gint) -->
                        <child>
                          <object class="GtkTreeViewColumn" id="col_cap">
                            <property name="title">Capacity</property>
                            <property name="resizable">True</property>
                            <child>
                              <object class="GtkCellRendererText"/>
                              <attributes>
                                <attribute name="text">5</attribute>
                              </attributes>
                            </child>
                          </object>
                        </child>

                        <!-- Column 6 — % Stock -->
                        <child>
                          <object class="GtkTreeViewColumn" id="col_per">
                            <property name="title">% Stock</property>
                            <property name="resizable">True</property>
                            <child>
                              <object class="GtkCellRendererText"/>
                              <attributes>
                                <attribute name="text">6</attribute>
                              </attributes>
                            </child>
                          </object>
                        </child>

                        <!-- Column 7 — Status -->
                        <child>
                          <object class="GtkTreeViewColumn" id="col_status">
                            <property name="title">Status</property>
                            <property name="resizable">True</property>
                            <child>
                              <object class="GtkCellRendererText"/>
                              <attributes>
                                <attribute name="text">7</attribute>
                              </attributes>
                            </child>
                          </object>
                        </child>

                      </object>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">True</property>
                    <property name="fill">True</property>
                  </packing>
                </child>

                <!-- Item count status label -->
                <child>
                  <object class="GtkLabel" id="stock_status_label">
                    <property name="label">Loaded 0 items</property>
                    <property name="xalign">0</property>
                    <property name="margin-start">8</property>
                    <property name="margin-bottom">4</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">False</property>
                  </packing>
                </child>

              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel">
                <property name="label">Stock</property>
              </object>
            </child>

            <!-- ════════════════════════════════════════════════════
                 PAGE 1 — Add Item Form
            ════════════════════════════════════════════════════ -->
            <child>
              <object class="GtkBox" id="add_page_box">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <property name="margin">20</property>

                <!-- Frame wraps the input grid -->
                <child>
                  <object class="GtkFrame" id="add_frame">
                    <property name="label">Add New Item</property>
                    <child>
                      <object class="GtkGrid" id="add_grid">
                        <property name="row-spacing">10</property>
                        <property name="column-spacing">15</property>
                        <property name="margin">20</property>

                        <!-- Row 0 — Barcode -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Barcode:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">0</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkEntry" id="entry_bar">
                            <property name="hexpand">True</property>
                            <property name="max-length">14</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">0</property>
                          </packing>
                        </child>

                        <!-- Row 1 — Name -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Name:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">1</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkEntry" id="entry_name">
                            <property name="hexpand">True</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">1</property>
                          </packing>
                        </child>

                        <!-- Row 2 — Price -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Price (&#8377;):</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">2</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkEntry" id="entry_price">
                            <property name="hexpand">True</property>
                            <property name="input-purpose">number</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">2</property>
                          </packing>
                        </child>

                        <!-- Row 3 — Stock -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Stock:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">3</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkSpinButton" id="spin_stock">
                            <property name="adjustment">adj_stock</property>
                            <property name="digits">0</property>
                            <property name="numeric">True</property>
                            <property name="hexpand">True</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">3</property>
                          </packing>
                        </child>

                        <!-- Row 4 — Capacity -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Capacity:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">4</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkSpinButton" id="spin_cap">
                            <property name="adjustment">adj_cap</property>
                            <property name="digits">0</property>
                            <property name="numeric">True</property>
                            <property name="hexpand">True</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">4</property>
                          </packing>
                        </child>

                        <!-- Row 5 — Transactions -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Transactions:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">5</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkSpinButton" id="spin_trans">
                            <property name="adjustment">adj_trans</property>
                            <property name="digits">0</property>
                            <property name="numeric">True</property>
                            <property name="hexpand">True</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">5</property>
                          </packing>
                        </child>

                        <!-- Row 6 — Status -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Status:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">6</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkComboBoxText" id="combo_status">
                            <property name="active">0</property>
                            <property name="hexpand">True</property>
                            <items>
                              <item translatable="yes">Active</item>
                              <item translatable="yes">Discontinued</item>
                            </items>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">6</property>
                          </packing>
                        </child>

                      </object>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                  </packing>
                </child>

                <!-- Action buttons (right-aligned below the frame) -->
                <child>
                  <object class="GtkBox" id="add_btn_box">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">10</property>
                    <property name="halign">end</property>
                    <child>
                      <object class="GtkButton" id="btn_add_item">
                        <property name="label">Add Item</property>
                        <signal name="clicked" handler="on_btn_add_item_clicked"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="btn_clear_form">
                        <property name="label">Clear Form</property>
                        <signal name="clicked" handler="on_btn_clear_form_clicked"/>
                      </object>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">False</property>
                  </packing>
                </child>

              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel">
                <property name="label">Add Item</property>
              </object>
            </child>

            <!-- ════════════════════════════════════════════════════
                 PAGE 2 — Search
            ════════════════════════════════════════════════════ -->
            <child>
              <object class="GtkBox" id="search_page_box">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <property name="margin">20</property>

                <!-- Slot 0: Search input bar -->
                <child>
                  <object class="GtkBox" id="search_bar_box">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">8</property>
                    <child>
                      <object class="GtkEntry" id="entry_search_bar">
                        <property name="placeholder-text">Enter barcode...</property>
                        <property name="hexpand">True</property>
                        <property name="max-length">14</property>
                      </object>
                      <packing>
                        <property name="expand">True</property>
                        <property name="fill">True</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkButton" id="btn_search">
                        <property name="label">Search</property>
                        <signal name="clicked" handler="on_btn_search_clicked"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="btn_ocr">
                        <property name="label">OCR Scan</property>
                        <signal name="clicked" handler="on_btn_ocr_clicked"/>
                      </object>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                  </packing>
                </child>

                <!-- Slot 1: Result frame -->
                <child>
                  <object class="GtkFrame" id="search_result_frame">
                    <property name="label">Result</property>
                    <child>
                      <object class="GtkGrid" id="result_grid">
                        <property name="row-spacing">8</property>
                        <property name="column-spacing">20</property>
                        <property name="margin">16</property>

                        <!-- Row 0 — Barcode -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Barcode:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">0</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_res_bar">
                            <property name="label">&#8212;</property>
                            <property name="xalign">0</property>
                            <property name="selectable">True</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">0</property>
                          </packing>
                        </child>

                        <!-- Row 1 — Name -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Name:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">1</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_res_name">
                            <property name="label">&#8212;</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">1</property>
                          </packing>
                        </child>

                        <!-- Row 2 — Price -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Price:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">2</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_res_price">
                            <property name="label">&#8212;</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">2</property>
                          </packing>
                        </child>

                        <!-- Row 3 — Stock -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Stock:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">3</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_res_stock">
                            <property name="label">&#8212;</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">3</property>
                          </packing>
                        </child>

                        <!-- Row 4 — Transactions -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Transactions:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">4</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_res_trans">
                            <property name="label">&#8212;</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">4</property>
                          </packing>
                        </child>

                        <!-- Row 5 — Capacity -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Capacity:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">5</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_res_cap">
                            <property name="label">&#8212;</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">5</property>
                          </packing>
                        </child>

                        <!-- Row 6 — % Stock -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">% Stock:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">6</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_res_per">
                            <property name="label">&#8212;</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">6</property>
                          </packing>
                        </child>

                        <!-- Row 7 — Status -->
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Status:</property>
                            <property name="xalign">1</property>
                            <property name="halign">end</property>
                          </object>
                          <packing>
                            <property name="left-attach">0</property>
                            <property name="top-attach">7</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_res_status">
                            <property name="label">&#8212;</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing>
                            <property name="left-attach">1</property>
                            <property name="top-attach">7</property>
                          </packing>
                        </child>

                      </object>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                  </packing>
                </child>

                <!-- Slot 2: Hint message label -->
                <child>
                  <object class="GtkLabel" id="search_msg_label">
                    <property name="label">Enter a barcode to search.</property>
                    <property name="xalign">0</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">False</property>
                  </packing>
                </child>

              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel">
                <property name="label">Search</property>
              </object>
            </child>

          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
          </packing>
        </child>

        <!-- ── Slot 3: Statusbar ───────────────────────────────────── -->
        <child>
          <object class="GtkStatusbar" id="statusbar"/>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
          </packing>
        </child>

      </object>
    </child>
  </object>

</interface>
